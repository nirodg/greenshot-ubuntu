<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Greenshot.Editor.Views.ColorPickerDialog"
        Title="Color"
        Width="280"
        SizeToContent="Height"
        CanResize="False"
        Background="#252525"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

  <Border Padding="12">
    <StackPanel Spacing="10">

      <TextBlock Text="SELECT COLOR"
                 Foreground="#888" FontSize="10" FontWeight="SemiBold"
                 LetterSpacing="1.5" Margin="0,0,0,4"/>

      <WrapPanel x:Name="ColorPanel" ItemWidth="36" ItemHeight="36"/>

      <Border Height="1" Background="#3A3A3A"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Cancel" Width="80"
                Background="#3A3A3A" Foreground="#DCDCDC"
                BorderThickness="0" CornerRadius="3"
                Click="OnCancel"/>
      </StackPanel>

    </StackPanel>
  </Border>
</Window>

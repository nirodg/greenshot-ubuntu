<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Greenshot.Editor.Views.TextEditDialog"
        Title="Edit Text"
        Width="440" Height="220"
        MinHeight="180"
        CanResize="True"
        Background="#252525"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

  <Border Padding="14">
    <Grid RowDefinitions="Auto,*,Auto">

      <TextBlock Grid.Row="0"
                 Text="EDIT TEXT"
                 Foreground="#888" FontSize="10" FontWeight="SemiBold"
                 LetterSpacing="1.5" Margin="0,0,0,8"/>

      <TextBox Grid.Row="1"
               x:Name="InputBox"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalContentAlignment="Top"
               FontSize="14"
               Background="#1E1E1E"
               Foreground="#DCDCDC"
               BorderBrush="#4A90D9"
               BorderThickness="1"
               CornerRadius="3"
               Padding="8"/>

      <StackPanel Grid.Row="2" Orientation="Horizontal"
                  HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="8">
        <Button Content="Cancel" Width="90"
                Background="#3A3A3A" Foreground="#DCDCDC"
                BorderThickness="0" CornerRadius="3"
                Click="OnCancel" IsCancel="True"/>
        <Button Content="OK" Width="90"
                Background="#2D5A8E" Foreground="White"
                BorderThickness="0" CornerRadius="3" FontWeight="Medium"
                Click="OnOk" IsDefault="True"/>
      </StackPanel>

    </Grid>
  </Border>
</Window>

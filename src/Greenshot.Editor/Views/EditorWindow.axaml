<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:drawing="clr-namespace:Greenshot.Editor.Drawing;assembly=Greenshot.Editor"
        x:Class="Greenshot.Editor.Views.EditorWindow"
        Title="Greenshot Editor"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Icon="/Assets/greenshot.ico">

  <Window.Styles>
    <!-- Tool button base -->
    <Style Selector="Button.tool">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="Margin" Value="0,1"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Foreground" Value="#C8C8C8"/>
    </Style>
    <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#3A3A3A"/>
    </Style>
    <Style Selector="Button.tool:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#505050"/>
    </Style>
    <!-- Active (selected) tool -->
    <Style Selector="Button.tool.active /template/ ContentPresenter">
      <Setter Property="Background" Value="#2D5A8E"/>
      <Setter Property="BorderBrush" Value="#4A90D9"/>
    </Style>
    <!-- Tool group separator -->
    <Style Selector="Border.tool-sep">
      <Setter Property="Height" Value="1"/>
      <Setter Property="Background" Value="#3A3A3A"/>
      <Setter Property="Margin" Value="6,4"/>
    </Style>
    <!-- Options bar label -->
    <Style Selector="TextBlock.opt-label">
      <Setter Property="Foreground" Value="#888"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="8,0,4,0"/>
    </Style>
    <!-- Small action button in options bar -->
    <Style Selector="Button.action">
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Margin" Value="4,0"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
  </Window.Styles>

  <!-- Root grid: menu top, tool panel left, options bar top, canvas fill -->
  <Grid RowDefinitions="Auto,Auto,*,24">

    <!-- ═══ Menu Bar ═══ -->
    <Menu Grid.Row="0" Background="#2B2B2B" Padding="4,2">
      <MenuItem Header="_File" Foreground="#DCDCDC">
        <MenuItem Header="_Save" InputGesture="Ctrl+S" Click="OnSave"/>
        <MenuItem Header="Save _As..." Click="OnSaveAs"/>
        <Separator/>
        <MenuItem Header="Export to _Clipboard" InputGesture="Ctrl+Shift+C" Click="OnCopyToClipboard"/>
        <Separator/>
        <MenuItem Header="_Close" InputGesture="Ctrl+W" Click="OnClose"/>
      </MenuItem>
      <MenuItem Header="_Edit" Foreground="#DCDCDC">
        <MenuItem Header="_Undo" InputGesture="Ctrl+Z" Click="OnUndo"/>
        <MenuItem Header="_Redo" InputGesture="Ctrl+Y" Click="OnRedo"/>
        <Separator/>
        <MenuItem Header="Select _All" InputGesture="Ctrl+A" Click="OnSelectAll"/>
        <MenuItem Header="_Delete Selected" InputGesture="Delete" Click="OnDeleteSelected"/>
      </MenuItem>
      <MenuItem Header="_View" Foreground="#DCDCDC">
        <MenuItem Header="Zoom In"       InputGesture="Ctrl+OemPlus"  Click="OnZoomIn"/>
        <MenuItem Header="Zoom Out"      InputGesture="Ctrl+OemMinus" Click="OnZoomOut"/>
        <MenuItem Header="Fit to Window" InputGesture="Ctrl+0"        Click="OnZoomFit"/>
      </MenuItem>
    </Menu>

    <!-- ═══ Options / Context Bar ═══ -->
    <Border Grid.Row="1" Background="#2B2B2B"
            BorderBrush="#3A3A3A" BorderThickness="0,0,0,1"
            Height="38">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">

        <!-- Undo / Redo quick buttons -->
        <Button Classes="action" ToolTip.Tip="Undo (Ctrl+Z)" Click="OnUndo"
                Background="Transparent" Foreground="#DCDCDC" BorderThickness="0" Padding="6,2">
          <TextBlock Text="↩" FontSize="15"/>
        </Button>
        <Button Classes="action" ToolTip.Tip="Redo (Ctrl+Y)" Click="OnRedo"
                Background="Transparent" Foreground="#DCDCDC" BorderThickness="0" Padding="6,2">
          <TextBlock Text="↪" FontSize="15"/>
        </Button>

        <Border Width="1" Height="22" Background="#3A3A3A" Margin="6,0"/>

        <!-- Color swatch -->
        <TextBlock Classes="opt-label" Text="Color"/>
        <Border x:Name="ColorPreview"
                Width="28" Height="22" Background="Red"
                CornerRadius="3" Cursor="Hand"
                BorderBrush="#555" BorderThickness="1"
                ToolTip.Tip="Click to change color"
                PointerPressed="OnColorClick"/>

        <Border Width="1" Height="22" Background="#3A3A3A" Margin="8,0"/>

        <!-- Line size -->
        <TextBlock Classes="opt-label" Text="Size"/>
        <ComboBox x:Name="ThicknessCombo" Width="64" Height="26"
                  SelectedIndex="1" SelectionChanged="OnThicknessChanged"
                  Background="#3A3A3A" Foreground="#DCDCDC"
                  BorderBrush="#555" FontSize="12">
          <ComboBoxItem Content="1 px"/>
          <ComboBoxItem Content="2 px"/>
          <ComboBoxItem Content="3 px"/>
          <ComboBoxItem Content="5 px"/>
          <ComboBoxItem Content="8 px"/>
          <ComboBoxItem Content="12 px"/>
        </ComboBox>

        <Border Width="1" Height="22" Background="#3A3A3A" Margin="8,0"/>

        <!-- Zoom -->
        <TextBlock Classes="opt-label" Text="Zoom"/>
        <Button Classes="action" ToolTip.Tip="Zoom In (Ctrl++)"  Click="OnZoomIn"
                Background="#3A3A3A" Foreground="#DCDCDC" BorderThickness="0" Padding="6,2">
          <TextBlock Text="＋" FontSize="13"/>
        </Button>
        <Button Classes="action" ToolTip.Tip="Zoom Out (Ctrl+-)" Click="OnZoomOut"
                Background="#3A3A3A" Foreground="#DCDCDC" BorderThickness="0" Padding="6,2">
          <TextBlock Text="－" FontSize="13"/>
        </Button>
        <Button Classes="action" ToolTip.Tip="Fit to Window (Ctrl+0)" Click="OnZoomFit"
                Background="#3A3A3A" Foreground="#DCDCDC" BorderThickness="0" Padding="6,2">
          <TextBlock Text="⊡" FontSize="13"/>
        </Button>

        <Border Width="1" Height="22" Background="#3A3A3A" Margin="8,0"/>

        <!-- Save / Copy quick buttons -->
        <Button Classes="action" ToolTip.Tip="Save (Ctrl+S)" Click="OnSave"
                Background="#2D5A8E" Foreground="White" BorderThickness="0"
                CornerRadius="3" Padding="10,3" Margin="4,0">
          <TextBlock Text="Save" FontSize="12" FontWeight="Medium"/>
        </Button>
        <Button Classes="action" ToolTip.Tip="Copy to Clipboard" Click="OnCopyToClipboard"
                Background="#3A3A3A" Foreground="#DCDCDC" BorderThickness="0"
                CornerRadius="3" Padding="10,3">
          <TextBlock Text="Copy" FontSize="12"/>
        </Button>
      </StackPanel>
    </Border>

    <!-- ═══ Main Work Area: tool panel + canvas ═══ -->
    <Grid Grid.Row="2" ColumnDefinitions="52,*">

      <!-- Left Tool Panel (Photoshop-style vertical strip) -->
      <Border Grid.Column="0" Background="#252525"
              BorderBrush="#3A3A3A" BorderThickness="0,0,1,0">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center"
                    VerticalAlignment="Top" Margin="0,8">

          <!-- Select -->
          <Button x:Name="BtnSelect" Classes="tool" ToolTip.Tip="Select / Move (V)"
                  Click="OnModeSelect">
            <TextBlock Text="↖" FontSize="18" HorizontalAlignment="Center"/>
          </Button>

          <Border Classes="tool-sep"/>

          <!-- Rectangle -->
          <Button x:Name="BtnRect" Classes="tool" ToolTip.Tip="Rectangle (R)"
                  Click="OnModeRect">
            <Border BorderBrush="#C8C8C8" BorderThickness="2"
                    Width="18" Height="13"/>
          </Button>

          <!-- Ellipse -->
          <Button x:Name="BtnEllipse" Classes="tool" ToolTip.Tip="Ellipse (E)"
                  Click="OnModeEllipse">
            <Ellipse Stroke="#C8C8C8" StrokeThickness="2" Width="18" Height="13"/>
          </Button>

          <!-- Arrow -->
          <Button x:Name="BtnArrow" Classes="tool" ToolTip.Tip="Arrow (A)"
                  Click="OnModeArrow">
            <TextBlock Text="➜" FontSize="17" HorizontalAlignment="Center"/>
          </Button>

          <!-- Text -->
          <Button x:Name="BtnText" Classes="tool" ToolTip.Tip="Text (T)"
                  Click="OnModeText">
            <TextBlock Text="T" FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
          </Button>

          <!-- Freehand -->
          <Button x:Name="BtnFreehand" Classes="tool" ToolTip.Tip="Freehand (F)"
                  Click="OnModeFreehand">
            <TextBlock Text="✏" FontSize="17" HorizontalAlignment="Center"/>
          </Button>

          <Border Classes="tool-sep"/>

          <!-- Highlight -->
          <Button x:Name="BtnHighlight" Classes="tool" ToolTip.Tip="Highlight (H)"
                  Click="OnModeHighlight">
            <Border Background="#BFFFFF00" Width="18" Height="13" CornerRadius="2"/>
          </Button>

          <!-- Blur / Obfuscate -->
          <Button x:Name="BtnObfuscate" Classes="tool" ToolTip.Tip="Blur / Obfuscate (B)"
                  Click="OnModeObfuscate">
            <Grid Width="18" Height="13">
              <Border Background="#505050" CornerRadius="2"/>
              <TextBlock Text="⬛" FontSize="10" HorizontalAlignment="Center"
                         VerticalAlignment="Center" Foreground="#888"/>
            </Grid>
          </Button>

          <Border Classes="tool-sep"/>

          <!-- Delete selected -->
          <Button Classes="tool" ToolTip.Tip="Delete selected (Del)"
                  Click="OnDeleteSelected">
            <TextBlock Text="🗑" FontSize="16" HorizontalAlignment="Center"/>
          </Button>

        </StackPanel>
      </Border>

      <!-- Canvas Area -->
      <ScrollViewer Grid.Column="1"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Background="#1A1A1A">
        <!-- Checkerboard-style dark canvas bg -->
        <Border Padding="16">
          <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" OffsetX="0" OffsetY="4" Opacity="0.6"/>
          </Border.Effect>
          <drawing:Surface x:Name="EditorSurface"/>
        </Border>
      </ScrollViewer>

    </Grid>

    <!-- ═══ Status Bar ═══ -->
    <Border Grid.Row="3" Background="#2B2B2B"
            BorderBrush="#3A3A3A" BorderThickness="0,1,0,0"
            Padding="10,0">
      <TextBlock x:Name="StatusLabel" Text="Ready"
                 Foreground="#888" FontSize="11"
                 VerticalAlignment="Center"/>
    </Border>

  </Grid>
</Window>
